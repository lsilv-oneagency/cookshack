# Copy this file to .env.local and fill in your values.
MIVA_STORE_URL=https://www.your-domain.com
MIVA_STORE_CODE=your_store_code
MIVA_API_TOKEN=your_api_token_here
MIVA_SIGNING_KEY=your_base64_signing_key_here
MIVA_SIGNING_DIGEST=sha256
NEXT_PUBLIC_STORE_URL=https://www.your-domain.com

# Optional: Miva category code for recipe/content products (/recipes/view/[code]).
# Defaults to ctgy_recipes if unset.
# MIVA_RECIPES_CATEGORY_CODE=ctgy_recipes
