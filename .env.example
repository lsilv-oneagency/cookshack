# Copy this file to .env.local and fill in your values.
MIVA_STORE_URL=https://www.your-domain.com
MIVA_STORE_CODE=your_store_code
MIVA_API_TOKEN=your_api_token_here
MIVA_SIGNING_KEY=your_base64_signing_key_here
MIVA_SIGNING_DIGEST=sha256
NEXT_PUBLIC_STORE_URL=https://www.your-domain.com
# Optional: path on the Miva store for sign-in (defaults to /sign-in). Set if your store uses /account, etc.
# NEXT_PUBLIC_STORE_SIGN_IN_PATH=/sign-in

# HTTP Basic for mm5/json.mvc and /api/img if your store requires it.
# MIVA_HTTP_USER=
# MIVA_HTTP_PASS=   # If the password contains $, wrap in single quotes in .env.local

# Optional: Miva category code for recipe/content products (/recipes/view/[code]).
# Defaults to ctgy_recipes if unset.
# MIVA_RECIPES_CATEGORY_CODE=ctgy_recipes

# Optional: enables GET /api/health/miva (Bearer token). Probes json.mvc for HTTP Basic — set in Vercel only if you use this check.
# MIVA_DIAGNOSTIC_SECRET=
